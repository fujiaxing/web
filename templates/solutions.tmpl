{{ template "header" . }}
    <main>
        <!-- Page Title Section -->
        <section class="section bg-dark page-header">
            <div class="container reveal">
                <h1 class="main-title">行业解决方案</h1>
                <p class="sub-title">深耕 23 大行业，基于用友 BIP 提供全域数智化转型方案，助力企业商业创新</p>
            </div>
        </section>

        <!-- Industry Grid -->
        <section class="section">
            <div class="container">
                <div class="grid">
                    <!-- 工业与制造 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="factory" style="width: 32px; height: 32px;"></i></div>
                        <h3>工业与制造</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">涵盖离散制造、流程制造、装备制造等，实现智能工厂与全价值链协同。</p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">智能制造</span>
                            <span class="feature-tag">工业互联</span>
                            <span class="feature-tag">MES/MOM</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>

                    <!-- 消费品与零售 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="shopping-cart" style="width: 32px; height: 32px;"></i></div>
                        <h3>消费品与零售</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">打通线上线下全渠道，重塑品牌与消费者连接，实现数智化营销。</p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">全渠道营销</span>
                            <span class="feature-tag">会员管理</span>
                            <span class="feature-tag">智慧零售</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>

                    <!-- 能源与公用事业 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="zap" style="width: 32px; height: 32px;"></i></div>
                        <h3>能源与公用事业</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">助力电力、油气、矿山等能源企业实现绿色安全、高效低碳的数智化升级。</p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">智慧能源</span>
                            <span class="feature-tag">资产管理</span>
                            <span class="feature-tag">安全生产</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>

                    <!-- 建筑与地产 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="building" style="width: 32px; height: 32px;"></i></div>
                        <h3>建筑与地产</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">全生命周期数智化管理，提升项目管控效率，赋能智慧建筑。 </p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">项目管控</span>
                            <span class="feature-tag">智慧工地</span>
                            <span class="feature-tag">地产数智化</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>

                    <!-- 交通与物流 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="truck" style="width: 32px; height: 32px;"></i></div>
                        <h3>交通与物流</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">构建智慧物流体系，提升物流效率与服务质量，实现物流全链路可视化。</p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">智慧物流</span>
                            <span class="feature-tag">运输管理</span>
                            <span class="feature-tag">多式联运</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>

                    <!-- 金融行业 -->
                    <div class="card reveal">
                        <div class="card-icon"><i data-lucide="landmark" style="width: 32px; height: 32px;"></i></div>
                        <h3>金融行业</h3>
                        <p style="margin-bottom: 24px; color: #666; font-size: 16px;">为银行、保险、证券等提供深度金融科技方案，助力金融机构数智化运营。</p>
                        <div style="margin-bottom: 30px;">
                            <span class="feature-tag">数字银行</span>
                            <span class="feature-tag">智慧金融</span>
                            <span class="feature-tag">风险管理</span>
                        </div>
                        <a href="#" style="color: var(--primary); text-decoration: none; font-weight: 800; display: flex; align-items: center;">了解详情 <i data-lucide="arrow-up-right" style="margin-left: 6px;"></i></a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Platform Strategy -->
        <section class="section bg-light">
            <div class="container">
                <div class="section-header reveal">
                    <h2>平台 + 行业 战略</h2>
                    <p>依托用友 BIP 数智化底座，深度融合行业场景，提供全域创新服务</p>
                </div>
                <div class="grid">
                    <div class="case-card reveal">
                        <div style="color: var(--primary); margin-bottom: 24px;"><i data-lucide="database" style="width: 40px; height: 40px;"></i></div>
                        <h3>数据驱动</h3>
                        <p>沉淀行业数据资产，通过数据中台实现实时洞察与智能决策。</p>
                    </div>
                    <div class="case-card reveal">
                        <div style="color: var(--primary); margin-bottom: 24px;"><i data-lucide="layout" style="width: 40px; height: 40px;"></i></div>
                        <h3>场景化方案</h3>
                        <p>深入前端业务场景，提供满足行业特性的模块化、可配置应用。</p>
                    </div>
                    <div class="case-card reveal">
                        <div style="color: var(--primary); margin-bottom: 24px;"><i data-lucide="share-2" style="width: 40px; height: 40px;"></i></div>
                        <h3>生态协同</h3>
                        <p>联合行业合作伙伴，构建共生共赢的数智化服务生态圈。</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="section" style="padding-top: 0;">
            <div class="container reveal">
                <div class="cta-banner" style="background: linear-gradient(135deg, var(--primary) 0%, #ff4d4d 100%); padding: 60px; border-radius: 20px; text-align: center; color: white;">
                    <h2 style="margin-bottom: 20px; font-size: 32px;">获取您的行业定制化方案</h2>
                    <p style="margin-bottom: 40px; opacity: 0.9; font-size: 18px;">我们的行业专家将为您提供深度咨询与演示，开启您的数智化转型之旅。</p>
                    <a href="#" class="btn btn-primary consult-btn" style="background: white !important; color: var(--primary) !important; border: none;">立即预约演示 <i data-lucide="chevron-right" style="margin-left: 8px; width: 20px;"></i></a>
                </div>
            </div>
        </section>
    </main>
{{ template "footer" . }}
