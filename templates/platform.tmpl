{{ template "header" . }}
    <main>
        <!-- Platform Hero Section -->
        <section class="section bg-dark platform-hero">
            <div class="container reveal">
                <div style="color: var(--primary); font-weight: 800; margin-bottom: 24px; letter-spacing: 2px; display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="zap" style="margin-right: 10px;"></i> POWERED BY IUAP
                </div>
                <h1 class="main-title" style="font-size: 64px; line-height: 1.1; margin-bottom: 32px;">用友 iuap <br>更懂企业的数智化平台底座</h1>
                <p class="sub-title" style="max-width: 900px; margin: 0 auto 48px; font-size: 22px; opacity: 0.8; line-height: 1.6;">
                    基于云原生、元数据驱动、中台化和数智化核心技术，助力企业构建高弹性、高可用、安全可信的数智化基础设施，加速商业创新。
                </p>
                <div style="display: flex; gap: 20px; justify-content: center;">
                    <a href="#" class="btn btn-primary consult-btn">立即体验</a>
                    <a href="#" class="btn btn-outline consult-btn" style="border-color: rgba(255,255,255,0.3); color: white;">技术白皮书 <i data-lucide="download" style="margin-left: 8px; width: 18px;"></i></a>
                </div>
            </div>
        </section>

        <!-- Core Platforms Grid -->
        <section class="section">
            <div class="container">
                <div class="section-header reveal">
                    <h2>四大核心能力，支撑企业全域创新</h2>
                    <p>打通企业从技术底层到业务应用的全链路，实现技术赋能业务</p>
                </div>
                <div class="grid">
                    <!-- 技术平台 -->
                    <div class="card reveal">
                        <div class="card-icon" style="background: rgba(238,34,35,0.1); color: var(--primary);"><i data-lucide="cpu" style="width: 32px; height: 32px;"></i></div>
                        <h3 style="font-size: 24px; margin-bottom: 16px;">技术平台</h3>
                        <p style="color: #666; line-height: 1.7; margin-bottom: 24px;">提供高可用、高并发、安全可靠的云原生技术架构，支撑企业级应用的快速部署与弹性伸缩。</p>
                        <ul style="list-style: none; padding: 0; color: #444; font-size: 15px;">
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 云原生技术架构</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 混合云部署与管理</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 高效 DevOps 体系</li>
                        </ul>
                    </div>

                    <!-- 低代码/中台平台 -->
                    <div class="card reveal">
                        <div class="card-icon" style="background: rgba(238,34,35,0.1); color: var(--primary);"><i data-lucide="layout" style="width: 32px; height: 32px;"></i></div>
                        <h3 style="font-size: 24px; margin-bottom: 16px;">低代码/中台平台</h3>
                        <p style="color: #666; line-height: 1.7; margin-bottom: 24px;">基于元数据驱动，提供可视化开发工具与业务中台能力，让业务人员也能参与创新。</p>
                        <ul style="list-style: none; padding: 0; color: #444; font-size: 15px;">
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> YonBuilder 低代码开发</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 业务中台 (YMS)</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 全生命周期应用管理</li>
                        </ul>
                    </div>

                    <!-- 数据中台 -->
                    <div class="card reveal">
                        <div class="card-icon" style="background: rgba(238,34,35,0.1); color: var(--primary);"><i data-lucide="database" style="width: 32px; height: 32px;"></i></div>
                        <h3 style="font-size: 24px; margin-bottom: 16px;">数据中台</h3>
                        <p style="color: #666; line-height: 1.7; margin-bottom: 24px;">打破数据孤岛，实现数据资产化、服务化，为企业提供实时、精准的数据决策支持。</p>
                        <ul style="list-style: none; padding: 0; color: #444; font-size: 15px;">
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 数据集成与治理</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 实时湖仓架构</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 数据 API 服务</li>
                        </ul>
                    </div>

                    <!-- 智能中台 -->
                    <div class="card reveal">
                        <div class="card-icon" style="background: rgba(238,34,35,0.1); color: var(--primary);"><i data-lucide="brain-circuit" style="width: 32px; height: 32px;"></i></div>
                        <h3 style="font-size: 24px; margin-bottom: 16px;">智能中台 (YonGPT)</h3>
                        <p style="color: #666; line-height: 1.7; margin-bottom: 24px;">融合企业级大模型，提供 AI 助手、智能分析等场景化 AI 服务，赋能企业智能化升级。</p>
                        <ul style="list-style: none; padding: 0; color: #444; font-size: 15px;">
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 企业级大模型 YonGPT</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 预置行业 AI 模型</li>
                            <li style="margin-bottom: 10px;"><i data-lucide="check-circle-2" style="width: 16px; color: var(--primary); margin-right: 8px; vertical-align: middle;"></i> 智能机器人应用</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Architecture Showcase -->
        <section class="section bg-light overflow-hidden">
            <div class="container">
                <div class="platform-grid" style="align-items: center;">
                    <div class="reveal">
                        <h2 style="font-size: 40px; margin-bottom: 24px;">统一架构，无限可能</h2>
                        <p style="color: #666; font-size: 18px; margin-bottom: 32px; line-height: 1.8;">
                            用友 iuap 采用领先的“三中台+一平台”架构，通过统一的基础设施管理、统一的开发标准、统一的数据规范，帮助企业构建起坚实的数智化底座。
                        </p>
                        <div class="feature-item" style="display: flex; gap: 20px; margin-bottom: 24px;">
                            <div style="flex-shrink: 0; width: 48px; height: 48px; border-radius: 12px; background: white; display: flex; align-items: center; justify-content: center; color: var(--primary); box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                                <i data-lucide="layers"></i>
                            </div>
                            <div>
                                <h4 style="margin-bottom: 8px; font-size: 20px;">跨云弹性调度</h4>
                                <p style="color: #666;">屏蔽底层 IaaS 差异，支持全球主流公有云及私有云环境，实现资源统一管控。</p>
                            </div>
                        </div>
                        <div class="feature-item" style="display: flex; gap: 20px;">
                            <div style="flex-shrink: 0; width: 48px; height: 48px; border-radius: 12px; background: white; display: flex; align-items: center; justify-content: center; color: var(--primary); box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                                <i data-lucide="share-2"></i>
                            </div>
                            <div>
                                <h4 style="margin-bottom: 8px; font-size: 20px;">连接与集成平台 (YonLinker)</h4>
                                <p style="color: #666;">支持云云集成、云端集成、端端集成，连接企业内外一切业务资产。</p>
                            </div>
                        </div>
                    </div>
                    <div class="reveal">
                        <div style="background: white; padding: 40px; border-radius: 32px; box-shadow: 0 40px 100px rgba(0,0,0,0.05); position: relative;">
                            <!-- Architecture Diagram (Abstract) -->
                            <div style="border: 2px dashed #eee; border-radius: 16px; padding: 20px; text-align: center; margin-bottom: 20px;">
                                <div style="font-weight: 800; color: #999; margin-bottom: 15px; font-size: 12px; text-transform: uppercase;">应用服务层</div>
                                <div style="display: flex; gap: 10px; justify-content: center;">
                                    <div style="background: #f8f8f8; padding: 8px 16px; border-radius: 6px; font-size: 13px;">财务</div>
                                    <div style="background: #f8f8f8; padding: 8px 16px; border-radius: 6px; font-size: 13px;">供应链</div>
                                    <div style="background: #f8f8f8; padding: 8px 16px; border-radius: 6px; font-size: 13px;">人力</div>
                                </div>
                            </div>
                            <div style="background: var(--primary); color: white; border-radius: 16px; padding: 30px; text-align: center; margin-bottom: 20px;">
                                <div style="font-weight: 800; margin-bottom: 10px;">iuap 平台底座</div>
                                <div style="font-size: 14px; opacity: 0.9;">三中台 + 一平台 (技术/业务/数据/AI)</div>
                            </div>
                            <div style="border: 2px solid #eee; border-radius: 16px; padding: 20px; text-align: center;">
                                <div style="font-weight: 800; color: #666; margin-bottom: 10px; font-size: 12px; text-transform: uppercase;">基础设施层 (IaaS)</div>
                                <div style="display: flex; gap: 10px; justify-content: center; font-size: 13px; color: #888;">
                                    <span>阿里云</span> | <span>腾讯云</span> | <span>华为云</span> | <span>私有云</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Advantages Section -->
        <section class="section">
            <div class="container">
                <div class="section-header reveal">
                    <h2>为什么选择 iuap 平台？</h2>
                    <p>为大型企业数智化转型量身定制的顶级平台底座</p>
                </div>
                <div class="grid">
                    <div class="case-card reveal" style="padding: 40px;">
                        <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 24px;">自主可控</h3>
                        <p style="color: #666;">核心技术完全自主研发，支持全栈国产化适配，保障企业信息安全与合规性。</p>
                    </div>
                    <div class="case-card reveal" style="padding: 40px;">
                        <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 24px;">行业积淀</h3>
                        <p style="color: #666;">沉淀用友 36 年服务企业经验，内置大量行业领域模型，大幅降低开发成本。</p>
                    </div>
                    <div class="case-card reveal" style="padding: 40px;">
                        <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 24px;">开放生态</h3>
                        <p style="color: #666;">提供丰富的 API 与开发套件，支持第三方插件与生态应用无缝集成。</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="section cta-section">
            <div class="container reveal">
                <h2 class="main-title" style="color: white;">开启您的数智底座建设</h2>
                <p class="sub-title" style="color: white; opacity: 0.9;">立即联系专家，获取为您定制的平台建设方案</p>
                <div class="cta-btns">
                    <a href="#" class="btn btn-primary consult-btn" style="background: white !important; color: var(--primary) !important; border: none;">预约演示 <i data-lucide="chevron-right" style="margin-left: 8px; width: 20px;"></i></a>
                    <a href="#" class="btn btn-outline consult-btn" style="border-color: rgba(255,255,255,0.3); color: white;">联系我们</a>
                </div>
            </div>
        </section>
    </main>
{{ template "footer" . }}
