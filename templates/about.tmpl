{{ template "header" . }}
    <main>
        <!-- About Hero -->
        <section class="section bg-dark" style="padding-top: 200px; padding-bottom: 120px; text-align: center; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://hbyonyou.cn/web/photo-1497366216548-37526070297c.jpg?auto=format&fit=crop&q=80&w=1600') center/cover !important;">
            <div class="container reveal">
                <h1 style="font-size: 64px; font-weight: 900; margin-bottom: 24px; color: white;">懂企业，更懂数智化</h1>
                <p style="color: #ccc; font-size: 24px; max-width: 800px; margin: 0 auto; line-height: 1.6;">武汉兴诺佳盛科技有限公司 — 湖北地区领先的 IT 咨询与服务提供商</p>
            </div>
        </section>

        <!-- Company Introduction -->
        <section class="section">
            <div class="container">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
                    <div class="reveal">
                        <div style="color: var(--primary); font-weight: 800; margin-bottom: 16px; letter-spacing: 2px;">WHO WE ARE</div>
                        <h2 style="font-size: 42px; margin-bottom: 32px; font-weight: 800;">根植湖北，服务全国</h2>
                        <p style="font-size: 18px; color: #555; margin-bottom: 24px; line-height: 1.8;">
                            武汉兴诺佳盛科技有限公司（简称“兴诺佳盛”）是**用友网络（yonyou）**及**致远互联（Seeyon）**在湖北省的核心合作伙伴。公司核心团队由原北京兴诺佳盛原班人马组建，拥有超过 10 年的企业信息化服务经验。
                        </p>
                        <p style="font-size: 18px; color: #555; margin-bottom: 32px; line-height: 1.8;">
                            我们致力于为大型企业及成长型企业提供全生命周期的数智化转型服务，涵盖 IT 咨询、软件销售、系统实施、定制开发及后期运维。目前已累计服务超过 200 家优质客户，完成 500 余项数智化工程。
                        </p>
                        <div style="display: flex; gap: 40px;">
                            <div>
                                <h4 style="font-size: 32px; color: var(--primary); font-weight: 900;">200+</h4>
                                <p style="color: #888; font-weight: 600;">活跃客户</p>
                            </div>
                            <div>
                                <h4 style="font-size: 32px; color: var(--primary); font-weight: 900;">500+</h4>
                                <p style="color: #888; font-weight: 600;">成功案例</p>
                            </div>
                            <div>
                                <h4 style="font-size: 32px; color: var(--primary); font-weight: 900;">10+</h4>
                                <p style="color: #888; font-weight: 600;">年行业积淀</p>
                            </div>
                        </div>
                    </div>
                    <div class="reveal">
                        <img src="https://img.hbyonyou.cn/web/photo-1522071820081-009f0129c71c.jpg?auto=format&fit=crop&q=80&w=1000" alt="Team Work" style="width: 100%; border-radius: 20px; box-shadow: var(--shadow-lg);">
                    </div>
                </div>
            </div>
        </section>

        <!-- Our Values -->
        <section class="section bg-light">
            <div class="container">
                <div class="section-header reveal">
                    <h2>专业定位与服务理念</h2>
                    <p>我们不仅是软件供应商，更是您值得信赖的数智化合作伙伴</p>
                </div>
                <div class="grid">
                    <div class="card reveal" style="padding: 40px; text-align: center;">
                        <div class="card-icon" style="margin: 0 auto 24px;"><i data-lucide="shield-check" style="width: 32px; height: 32px;"></i></div>
                        <h4 style="font-size: 22px; margin-bottom: 16px;">专业 IT 咨询</h4>
                        <p style="color: #666;">基于原北京团队深厚的技术背景，提供从顶层规划到业务落地的全方位咨询建议。</p>
                    </div>
                    <div class="card reveal" style="padding: 40px; text-align: center;">
                        <div class="card-icon" style="margin: 0 auto 24px;"><i data-lucide="users" style="width: 32px; height: 32px;"></i></div>
                        <h4 style="font-size: 22px; margin-bottom: 16px;">本地化精耕</h4>
                        <p style="color: #666;">深耕湖北市场，提供 7×24 小时快速响应机制，现场支持与远程指导无缝衔接。</p>
                    </div>
                    <div class="card reveal" style="padding: 40px; text-align: center;">
                        <div class="card-icon" style="margin: 0 auto 24px;"><i data-lucide="cog" style="width: 32px; height: 32px;"></i></div>
                        <h4 style="font-size: 22px; margin-bottom: 16px;">深度定制开发</h4>
                        <p style="color: #666;">依托用友 iuap 平台底座，针对企业个性化需求进行高效率、高质量的二次开发。</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Certifications & Honors -->
        <section class="section">
            <div class="container">
                <div class="section-header reveal">
                    <h2>资质荣誉</h2>
                    <p>权威认证，见证兴诺佳盛的专业服务实力</p>
                </div>
                
                <!-- Original Icons -->
                <div class="grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 60px;">
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm);" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)';">
                            <i data-lucide="award" style="width: 60px; height: 60px; color: var(--primary); margin-bottom: 20px;"></i>
                            <div style="font-weight: 800; color: #333; font-size: 16px;">用友网络</div>
                            <div style="font-size: 14px; color: #888; margin-top: 10px;">核心授权合作伙伴</div>
                        </div>
                    </div>
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm);" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)';">
                            <i data-lucide="medal" style="width: 60px; height: 60px; color: var(--primary); margin-bottom: 20px;"></i>
                            <div style="font-weight: 800; color: #333; font-size: 16px;">致远互联</div>
                            <div style="font-size: 14px; color: #888; margin-top: 10px;">湖北区核心代理商</div>
                        </div>
                    </div>
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm);" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)';">
                            <i data-lucide="shield-check" style="width: 60px; height: 60px; color: var(--primary); margin-bottom: 20px;"></i>
                            <div style="font-weight: 800; color: #333; font-size: 16px;">软件企业证书</div>
                            <div style="font-size: 14px; color: #888; margin-top: 10px;">双软认证企业资质</div>
                        </div>
                    </div>
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm);" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)';">
                            <i data-lucide="badge-check" style="width: 60px; height: 60px; color: var(--primary); margin-bottom: 20px;"></i>
                            <div style="font-weight: 800; color: #333; font-size: 16px;">ISO9001认证</div>
                            <div style="font-size: 14px; color: #888; margin-top: 10px;">质量管理体系认证</div>
                        </div>
                    </div>
                </div>

                <!-- New Honor Images -->
                <div class="grid" style="grid-template-columns: repeat(3, 1fr); gap: 30px;">
                    <!-- Image 1: 核心授权合作伙伴 -->
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 15px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm); overflow: hidden;" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)'; this.style.boxShadow='var(--shadow-lg)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-sm)';">
                            <img src="https://img.hbyonyou.cn/gx.png" alt="用友核心授权合作伙伴" style="width: 100%; height: 100%; object-fit: contain; border-radius: 4px;">
                        </div>
                        <div style="font-weight: 800; color: #333; font-size: 18px; margin-top: 20px;">高新技术企业</div>
                        <div style="font-size: 14px; color: #888; margin-top: 8px;">核心授权合作伙伴</div>
                    </div>

                    <!-- Image 2: 2023 荣誉证书 -->
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 15px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm); overflow: hidden;" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)'; this.style.boxShadow='var(--shadow-lg)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-sm)';">
                            <img src="https://img.hbyonyou.cn/zs_2023.jpg" alt="2023 荣誉证书" style="width: 100%; height: 100%; object-fit: contain; border-radius: 4px;">
                        </div>
                        <div style="font-weight: 800; color: #333; font-size: 18px; margin-top: 20px;">用友网络</div>
                        <div style="font-size: 14px; color: #888; margin-top: 8px;">2023年度杰出贡献奖</div>
                    </div>

                    <!-- Image 3: 2022 荣誉证书 -->
                    <div class="reveal" style="text-align: center;">
                        <div style="width: 100%; aspect-ratio: 1/1.4; background: #fff; border: 1px solid var(--border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 15px; transition: all 0.4s; cursor: pointer; box-shadow: var(--shadow-sm); overflow: hidden;" onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-10px)'; this.style.boxShadow='var(--shadow-lg)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-sm)';">
                            <img src="https://img.hbyonyou.cn/zs_2022.jpg" alt="2022 荣誉证书" style="width: 100%; height: 100%; object-fit: contain; border-radius: 4px;">
                        </div>
                        <div style="font-weight: 800; color: #333; font-size: 18px; margin-top: 20px;">荣誉证书</div>
                        <div style="font-size: 14px; color: #888; margin-top: 8px;">2022年度优秀合作伙伴</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Partners -->
        <section class="section">
            <div class="container reveal">
                <div style="text-align: center; margin-bottom: 60px;">
                    <h3 style="font-size: 32px; font-weight: 800;">核心合作伙伴生态</h3>
                </div>
                <div style="display: flex; justify-content: space-around; align-items: center; filter: grayscale(1); opacity: 0.6;">
                    <span style="font-size: 28px; font-weight: 900;">yonyou 用友</span>
                    <span style="font-size: 28px; font-weight: 900;">Seeyon 致远互联</span>
                    <span style="font-size: 28px; font-weight: 900;">YonSuite</span>
                    <span style="font-size: 28px; font-weight: 900;">U9 Cloud</span>
                </div>
            </div>
        </section>
    </main>
{{ template "footer" . }}
